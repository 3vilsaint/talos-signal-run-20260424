{
  "name": "Talos Signal Run",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "runArgs": [
    "-p",
    "127.0.0.1:2396:2222"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "forwardPorts": [
    5173,
    4173,
    2222
  ],
  "portsAttributes": {
    "2222": {
      "label": "Container SSH",
      "onAutoForward": "ignore"
    }
  },
  "postCreateCommand": "sudo git config --system --add safe.directory \"$PWD\" && git config --global --add safe.directory \"$PWD\" && npm ci",
  "remoteUser": "node"
}
